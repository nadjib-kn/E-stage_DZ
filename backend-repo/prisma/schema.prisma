generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  role               String   // "student" | "company" | "admin"
  email              String   @unique
  password           String?
  googleId           String?  @unique
  status             String   @default("active") // "active" | "suspended"
  avatar             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Student-specific fields
  firstName          String?
  lastName           String?
  phone              String?
  university         String?
  major              String?
  graduationYear     String?
  skills             String?  // Stored as stringified JSON array
  resumeUrl          String?
  resumeName         String?
  portfolioUrl       String?
  githubUrl          String?

  // Company-specific fields
  companyName        String?
  industry           String?
  location           String?
  website            String?
  size               String?
  about              String?
  verificationStatus String?  @default("pending") // "pending" | "approved" | "rejected"
  nif                String?
  registreCommerce   String?

  // Relations
  jobs                 Job[]         @relation("CompanyJobs")
  applications         Application[] @relation("StudentApplications")
  ticketsReported      Ticket[]      @relation("ReporterTickets")
  ticketsReportedParty Ticket[]      @relation("ReportedPartyTickets")
}

model Job {
  id           String   @id @default(uuid())
  companyId    String
  role         String
  company      String
  location     String
  type         String
  duration     String?
  description  String?
  requirements String?
  tags         String?  // Stored as stringified JSON array
  status       String   @default("Active") // "Active" | "Closed" | "Draft" | "Blocked"
  deadline     String?
  logo         String?
  logoColor    String?
  createdAt    DateTime @default(now())

  // Relations
  companyRef   User          @relation("CompanyJobs", fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
}

model Application {
  id          String   @id @default(uuid())
  studentId   String
  jobId       String
  status      String   @default("Pending") // "Pending" | "Under Review" | "Interview" | "Accepted" | "Rejected"
  dateApplied DateTime @default(now())
  matchScore  Int?

  // Relations
  student     User @relation("StudentApplications", fields: [studentId], references: [id], onDelete: Cascade)
  job         Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([studentId, jobId])
}

model Ticket {
  id              String    @id @default(uuid())
  type            String    // "conflict" | "support" | "bug"
  status          String    @default("open") // "open" | "resolved" | "closed"
  subject         String
  description     String
  reporterId      String
  reportedPartyId String?
  dateOpened      DateTime  @default(now())
  resolvedAt      DateTime?

  // Relations
  reporter      User  @relation("ReporterTickets", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedParty User? @relation("ReportedPartyTickets", fields: [reportedPartyId], references: [id], onDelete: SetNull)
}
model Blacklist {
  id        String   @id @default(uuid())
  email     String   @unique
  reason    String?
  createdAt DateTime @default(now())
}
